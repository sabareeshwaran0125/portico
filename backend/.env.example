# Portico Backend Environment Variables Template
# Copy this file to .env and configure the values accordingly

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/portico?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# JWT Token Configuration (Must be at least 256 bits/32 characters)
JWT_SECRET=your_super_secret_jwt_signing_key_at_least_32_characters_long_for_security
# JWT Expirations in milliseconds (e.g. 1 hour for access token, 7 days for refresh token)
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# Razorpay Test Mode Credentials
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
